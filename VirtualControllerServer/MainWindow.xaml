<Window x:Class="VirtualControllerServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual Controller Server" 
        Height="850" Width="1300"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - QR Code & Status -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}" Margin="10" CornerRadius="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20">
                <TextBlock Text="Virtual Controller Server" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <!-- Server Status -->
                <Border Background="{StaticResource AccentBrush}" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Server Status" FontSize="14" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="{StaticResource WarningBrush}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="StatusText" Text="Stopped" Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="IpAddressText" Text="IP: --" Foreground="{StaticResource TextBrush}" Margin="0,5,0,0" FontSize="12"/>
                        <TextBlock x:Name="PortText" Text="Port: 5000" Foreground="{StaticResource TextBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- QR Code -->
                <Border Background="#FFFFFF" CornerRadius="10" Padding="10" Margin="0,0,0,20">
                    <Image x:Name="QrCodeImage" Width="220" Height="220" Stretch="Uniform"/>
                </Border>

                <TextBlock Text="Scan with your phone" 
                           FontSize="12" 
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,10"
                           Opacity="0.7"/>

                <TextBlock x:Name="UrlText" Text="http://--:5000" 
                           FontSize="11" 
                           Foreground="{StaticResource HighlightBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,20"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <!-- Control Buttons -->
                <Button x:Name="StartButton" Content="▶ Start Server" 
                        Style="{StaticResource ModernButton}" 
                        Click="StartButton_Click" Margin="0,0,0,10"/>
                
                <Button x:Name="StopButton" Content="■ Stop Server" 
                        Style="{StaticResource ModernButton}" 
                        Click="StopButton_Click" IsEnabled="False"/>

                <!-- Connected Count -->
                <Border Background="{StaticResource AccentBrush}" CornerRadius="10" Padding="15" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="Connected Controllers" FontSize="14" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ConnectedCountText" Text="0 / 8" FontSize="32" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Middle Panel - Layout Settings -->
        <Border Grid.Column="1" Background="{StaticResource SecondaryBrush}" Margin="0,10,10,10" CornerRadius="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15">
                <TextBlock Text="Controller Layout" 
                           FontSize="16" FontWeight="Bold" 
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,15"/>
                
                <!-- Preset Selector -->
                <TextBlock Text="Preset" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,5" Opacity="0.7"/>
                <ComboBox x:Name="PresetComboBox" 
                          SelectionChanged="PresetComboBox_SelectionChanged"
                          Background="{StaticResource AccentBrush}"
                          Foreground="{StaticResource TextBrush}"
                          BorderThickness="0"
                          Padding="10,8"
                          Margin="0,0,0,15"/>
                
                <!-- Toggle Buttons -->
                <TextBlock Text="Show Controls" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" Opacity="0.7"/>
                
                <CheckBox x:Name="ChkDPad" Content="D-Pad" 
                          Foreground="{StaticResource TextBrush}" 
                          IsChecked="True" Margin="0,0,0,8"
                          Checked="LayoutCheckbox_Changed" Unchecked="LayoutCheckbox_Changed"/>
                
                <CheckBox x:Name="ChkFaceButtons" Content="Face Buttons (A/B/X/Y)" 
                          Foreground="{StaticResource TextBrush}" 
                          IsChecked="True" Margin="0,0,0,8"
                          Checked="LayoutCheckbox_Changed" Unchecked="LayoutCheckbox_Changed"/>
                
                <CheckBox x:Name="ChkLeftStick" Content="Left Stick" 
                          Foreground="{StaticResource TextBrush}" 
                          IsChecked="True" Margin="0,0,0,8"
                          Checked="LayoutCheckbox_Changed" Unchecked="LayoutCheckbox_Changed"/>
                
                <CheckBox x:Name="ChkRightStick" Content="Right Stick" 
                          Foreground="{StaticResource TextBrush}" 
                          IsChecked="True" Margin="0,0,0,8"
                          Checked="LayoutCheckbox_Changed" Unchecked="LayoutCheckbox_Changed"/>
                
                <CheckBox x:Name="ChkBumpers" Content="Bumpers (LB/RB)" 
                          Foreground="{StaticResource TextBrush}" 
                          IsChecked="True" Margin="0,0,0,8"
                          Checked="LayoutCheckbox_Changed" Unchecked="LayoutCheckbox_Changed"/>
                
                <CheckBox x:Name="ChkTriggers" Content="Triggers (LT/RT)" 
                          Foreground="{StaticResource TextBrush}" 
                          IsChecked="True" Margin="0,0,0,8"
                          Checked="LayoutCheckbox_Changed" Unchecked="LayoutCheckbox_Changed"/>
                
                <CheckBox x:Name="ChkStartBack" Content="Start / Back" 
                          Foreground="{StaticResource TextBrush}" 
                          IsChecked="True" Margin="0,0,0,8"
                          Checked="LayoutCheckbox_Changed" Unchecked="LayoutCheckbox_Changed"/>
                
                <CheckBox x:Name="ChkGuide" Content="Guide Button" 
                          Foreground="{StaticResource TextBrush}" 
                          IsChecked="True" Margin="0,0,0,15"
                          Checked="LayoutCheckbox_Changed" Unchecked="LayoutCheckbox_Changed"/>
                
                <!-- Apply Button -->
                <Button x:Name="ApplyLayoutButton" Content="📱 Apply to Phones" 
                        Style="{StaticResource ModernButton}" 
                        Click="ApplyLayoutButton_Click"
                        IsEnabled="False"/>
                
                <TextBlock x:Name="LayoutStatusText" 
                           Text="" 
                           FontSize="11" 
                           Foreground="{StaticResource SuccessBrush}"
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Panel - Controllers Grid -->
        <Border Grid.Column="2" Background="{StaticResource SecondaryBrush}" Margin="0,10,10,10" CornerRadius="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                <ItemsControl x:Name="ControllersPanel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
